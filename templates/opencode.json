{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "fetch": {
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@0.0.50"
      ],
      "enabled": true,
      "type": "local"
    },
    "codegraph": {
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "command": {
    "gwd": {
      "templateFile": ".opencode/commands/gwd.md",
      "description": "Run grill-with-docs"
    },
    "ica": {
      "templateFile": ".opencode/commands/ica.md",
      "description": "Run improve-codebase-architecture"
    },
    "gm": {
      "templateFile": ".opencode/commands/gm.md",
      "description": "Run grill-me"
    },
    "tp": {
      "templateFile": ".opencode/commands/tp.md",
      "description": "Run to-spec"
    },
    "tc": {
      "templateFile": ".opencode/commands/tc.md",
      "description": "Run to-tickets"
    },
    "cw": {
      "templateFile": ".opencode/commands/cw.md",
      "description": "Run code-review"
    },
    "implement": {
      "templateFile": ".opencode/commands/implement.md",
      "description": "Run implement"
    }
  }
}
